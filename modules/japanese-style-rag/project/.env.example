# Root is auto-detected from pyproject.toml; override only when needed.
# JSTYLE_RAG_ROOT=/absolute/path/to/japanese-report-style-rag

# Vector backend: json is offline-friendly. chroma uses chromadb PersistentClient.
JSTYLE_VECTOR_BACKEND=json

# Embeddings: prefix with openai: to call an OpenAI-compatible / llama.cpp server.
JSTYLE_EMBEDDING_MODEL=openai:qwen3-embedding
JSTYLE_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
JSTYLE_EMBEDDING_API_KEY=
JSTYLE_ALLOW_HASH_EMBEDDINGS=0

# LLM provider: offline, ollama, or openai-compatible.
JSTYLE_LLM_PROVIDER=offline

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI-compatible API
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3-swallow

# FastAPI
JSTYLE_API_HOST=127.0.0.1
JSTYLE_API_PORT=8008
